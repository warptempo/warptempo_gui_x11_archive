#!/bin/bash
#run only from terminal
if [ ! -t 0 ]; then exit; fi
shopt -s nocaseglob
set -e
export LC_ALL=C

if [[ "$1" == help ]] || [[ "$1" == -h ]] || [[ "$1" == --help ]]; then
	echo "Iterate over tempo variations. Use +A, -B, etc in the warp markers file to increment or decrement tempo, then define ranges to iterate over these variables."
	echo
	echo "   Usage: "$(basename "$0")" <warpmarkers> <settings> <increment> [range range ...]"
	echo
	echo "The default inputs are .warpmarkers and .settings. To use other files, pass them as arguments before ranges. The default increment is 0.01. To use a different increment, pass it as an argument before ranges in the form i=<increment>. Range format is A±0.00,±0.01, etc. The first number must be less than the second. Outputs will be placed in the folder test."
	exit
fi

warpmarkers_file="$(ls .warpmarkers *.warpmarkers 2>/dev/null | head -n 1)"
settings_file="$(ls .settings *.settings 2>/dev/null | head -n 1)"

validation_errors=0

if [[ ! -f "$warpmarkers_file" ]]; then
	echo "Error: Warp markers file does not exist" && ((validation_errors++))
fi

if [[ ! -f "$settings_file" ]]; then
	echo "Error: Settings file does not exist" && ((validation_errors++))
fi

if [[ $validation_errors -gt 0 ]]; then
	exit 1
fi

for arg in "$@"; do
	if [[ "$arg" == *.warpmarkers ]]; then
		warpmarkers_file="$arg"
		shift
	fi
	if [[ "$arg" == *.settings ]]; then
		settings_file="$arg"
		shift
	fi
	if [[ "$arg" == i=* ]]; then
		increment="${arg#i=}"
		if [[ ! "$increment" =~ ^[0-9]*\.[0-9]{2}$ ]] || [[ $(echo "$increment < 0.01" | bc) -eq 1 ]]; then
			echo "Error: Increment must be a positive decimal with exactly 2 decimal places (e.g., 0.01, 0.05)."
			((validation_errors++))
		else
			increment=$(printf "%0.2f\n" "$increment")
		fi
		shift
	fi
done

if [[ -z "$increment" ]]; then
	increment=$(printf "%0.2f\n" 0.01)
fi

# Function to generate range for a given argument
generate_range() {
	local key=$1
	shift
	local lower_int=$1
	shift
	local upper_int=$1
	
	increment_int=$(echo "scale=0; ($increment * 100)/1" | bc)
	range_spread=$(printf "%.0f" $(echo "($upper_int-$lower_int+1)/$increment_int" | sed 's/--/+/' | bc -l))
	pad=${#range_spread}
	if [[ $pad -lt 2 ]]; then
		pad=2
	fi
	
	# Generate range
	for ((i=lower_int; i<=upper_int; i=$((i+increment_int)) )); do
		# Format number back to decimal with two places
		formatted=$(printf "%+.2f" $(echo "scale=2; $i/100" | bc))
		# Handle -0.00 case
		if [[ $formatted == "-0.00" ]]; then
			formatted="0.00"
		fi
		j=$(printf "%.0f" $(echo "($i-$lower_int)/$increment_int+1" | sed 's/--/+/' | bc -l))
		echo "$(printf "%0${pad}d" "$j"))$key$formatted"
	done
}

# Store all ranges, preserving order of arguments
declare -a keys
declare -A ranges
for arg in "$@"; do
	if [[ ! "$arg" =~ ^[A-Z][+-]?[0-9]+\.[0-9]{2},[+-]?[0-9]+\.[0-9]{2}$ ]]; then
		echo "Error: $arg is not a valid range. Format is A±0.00,±0.01, etc. The first value must be less than the second."
		((validation_errors++))
		continue
	fi
	# Extract key (first character)
	key=${arg:0:1}
	if [[ " ${keys[*]} " == *" $key "* ]]; then
		echo "Error: $key is used more than once."
		((validation_errors++))
	fi
	keys+=("$key")
	# Extract lower and upper bounds
	bounds=${arg:1}
	IFS=',' read -r lower upper <<< "$bounds"
	# Ensure proper decimal format for bc
	lower=$(echo "$lower" | sed 's/+//')
	upper=$(echo "$upper" | sed 's/+//')
	# Convert to integers (multiply by 100 to handle decimals)
	lower_int=$(echo "scale=0; ($lower * 100)/1" | bc -l)
	upper_int=$(echo "scale=0; ($upper * 100)/1" | bc -l)
	
	if [[ "$lower_int" -gt "$upper_int" ]]; then
		echo "Error: $arg is not a valid range. Format is A±0.00,±0.01, etc. The first value must be less than or equal to the second."
		((validation_errors++))
		continue
	fi
		
	ranges[$key]=$(generate_range "$key" "$lower_int" "$upper_int" | tr '\n' ' ')
done

if [[ -f test ]]; then
	echo "Error: A file called test exists." && ((validation_errors++))
fi

if [[ $validation_errors -gt 0 ]]; then
	exit 1
fi

# Function to generate permutations
generate_permutations() {
	local result=()
	
	# Recursive function to build permutations
	permute() {
		local depth=$1
		shift
		local prefix=$1
		
		if (( depth == ${#keys[@]} )); then
			# Remove trailing slash
			result+=("${prefix%/}")
			return
		fi
		
		local key=${keys[$depth]}
		# Convert range string to array
		IFS=' ' read -r -a values <<< "${ranges[$key]}"
		
		for value in "${values[@]}"; do
			permute $((depth + 1)) "$prefix$value/"
		done
	}
	
	permute 0 ""
	echo "${result[@]}"
}

# Store permutations in array
IFS=' ' read -r -a permutations <<< "$(generate_permutations)"
permutations_count=${#permutations[@]}
permutations_i=1

# Output permutations
for permutation in "${permutations[@]}"; do
	alternate_title="${permutation//)/) }"
	
	if [[ -f test/"$alternate_title".wav ]]; then
		echo "Skipping permutation $permutations_i of $permutations_count..."
		echo "Title: $alternate_title"
		((permutations_i++))
		continue
	fi

	echo "Creating permutation $permutations_i of $permutations_count..."
	echo "Title: $alternate_title"
	
	mkdir -p "$(dirname test/"$alternate_title".wav)"
	cp -f "$warpmarkers_file" test/"$alternate_title".warpmarkers
	cp -f "$settings_file" test/"$alternate_title".settings

	sed -i "s|title=.*|title=\"test\/$alternate_title\"|" test/"$alternate_title".settings
	
	IFS='/' read -r -a permutation_elements <<< "$permutation"
	
	for permutation_element in "${permutation_elements[@]}"; do
		permutation_element=${permutation_element#*)}
		key=${permutation_element:0:1}
		value=${permutation_element:1}
		
		sed -i "s|+$key|$value|g" test/"$alternate_title".warpmarkers
		if [[ "$value" == +* ]]; then
			inverted_value=${value/+/-}
		elif [[ "$value" == -* ]]; then
			inverted_value=${value/-/+}
		fi
		sed -i "s|-$key|$inverted_value|g" test/"$alternate_title".warpmarkers
	done
	
	"$(dirname "$0")"/warptempo test/"$alternate_title".warpmarkers test/"$alternate_title".settings
	
	((permutations_i++))
done



















