#!/bin/bash
# Run only from terminal
if [ ! -t 0 ]; then exit; fi
shopt -s nocaseglob
set -e
export LC_ALL=C

# Display help
if [[ "$1" == help ]] || [[ "$1" == -h ]] || [[ "$1" == --help ]]; then
	echo "Warp tempo by applying warp markers."
	echo
	echo "   Usage: "$(basename "$0")" <warpmarkers> <settings> [log]"
	echo
	echo "The default inputs are .warpmarkers and .settings. If these do not exist, run "$(basename "$0")" with no arguments to create blank templates. Log is optional. If provided, or if .log exists, the second column of .warpmarkers can contain a timestamp (MM:SS.mmm) to reference that point in the log."
	exit
fi

# Set default files
warpmarkers_file="${1:-"$(ls .warpmarkers *.warpmarkers 2>/dev/null | head -n 1)"}"
settings_file="${2:-"$(ls .settings *.settings 2>/dev/null | head -n 1)"}"
log_file="${3:-"$(ls .log 2>/dev/null | head -n 1)"}"
script_dir="$(dirname "$(realpath "$0")")"

# Create templates if no inputs found
if [[ -z "$1" ]] && [[ -z "$2" ]] && [[ ! -f "$warpmarkers_file" ]] && [[ ! -f "$settings_file" ]]; then
	warpmarkers_file=.warpmarkers
	settings_file=.settings
	echo "00:00.000|1.00" > "$warpmarkers_file"
	echo >> "$warpmarkers_file"
	echo title= > "$settings_file"
	echo audio_input= >> "$settings_file"
	echo url= >> "$settings_file"
	echo scale=1 >> "$settings_file"
	echo limiter=true >> "$settings_file"
	echo limit=-0.1 >> "$settings_file"
	echo browser=firefox >> "$settings_file"
	echo engine=warptempo >> "$settings_file"
	echo >> "$settings_file"
fi

preliminary_errors=0

# Check file existence and extensions
if [[ ! -f "$warpmarkers_file" ]]; then
	echo "Error: Warp markers file does not exist." && ((preliminary_errors++))
fi

if [[ "$warpmarkers_file" != *.warpmarkers ]]; then
	echo "Error: Warp markers file extension must be .warpmarkers." && ((preliminary_errors++))
fi

if [[ ! -f "$settings_file" ]]; then
	echo "Error: Settings file does not exist." && ((preliminary_errors++))
fi

if [[ "$settings_file" != *.settings ]]; then
	echo "Error: Settings file extension must be .settings." && ((preliminary_errors++))
fi

if [[ ! -z "$log_file" ]] && [[ ! -f "$log_file" ]]; then
	echo "Error: Log file does not exist." && ((preliminary_errors++))
fi

if [[ $preliminary_errors -gt 0 ]]; then
	exit 1
fi

# Load settings
. "$settings_file"

validation_errors=0

# Validate title and input source
if [[ -z "$title" ]]; then
	echo "Error: Title is required." && ((validation_errors++))
fi

if [[ -z "$audio_input" ]] && [[ -z "$url" ]]; then
	echo "Error: Url is required if audio input is not provided." && ((validation_errors++))
elif [[ ! -z "$audio_input" ]] && [[ ! -f "$audio_input" ]]; then
	echo "Error: Audio input file does not exist." && ((validation_errors++))
elif [[ ! -z "$audio_input" ]] && [[ -f "$audio_input" ]] && [[ "$(file --mime-type -b "$audio_input" | cut -d / -f 1)" != audio ]]; then
	echo "Error: Audio input file is not a valid audio file." && ((validation_errors++))
fi

# Validate scale
if [[ ! -z "$scale" ]] && [[ ! "$scale" =~ ^([0-9]*\.[0-9]+|[0-9]+\.?[0-9]*)$ ]]; then
	echo "Error: Scale is not a valid decimal." && ((validation_errors++))
elif [[ ! -z "$scale" ]]; then
	scale=$(printf "%0.6f\n" "$scale")
else
	scale=$(printf "%0.6f\n" 1)
fi

# Validate booleans
if [[ ! -z "$limiter" ]] && [[ "$limiter" != true ]] && [[ "$limiter" != false ]]; then
	echo "Error: Limiter must be true or false." && ((validation_errors++))
elif [[ -z "$limiter" ]]; then
	limiter=true
fi

# Validate limiter settings
if [[ ! -z "$limit" ]] && [[ ! "$limit" =~ ^-?[0-9]*(\.[0-9]+)?$ ]]; then
	echo "Error: Limit is not a valid decimal." && ((validation_errors++))
elif [[ ! -z "$limit" ]]; then
	limit=$(printf "%0.1f\n" "$limit")
else
	limit=$(printf "%0.1f\n" -0.1)
fi

# Validate browser for yt-dlp
if [[ ! -z "$browser" ]]; then
	supported_browsers=(brave chrome chromium edge firefox opera safari vivaldi whale none)
	supported=false
	for supported_browser in "${supported_browsers[@]}"; do
		if [[ "$browser" == "$supported_browser"* ]]; then
			supported=true
			break
		fi
	done
	if ! $supported; then
		echo -e "Error: Browser is not supported by yt-dlp. Enter one of the following:\n${supported_browsers[@]}\nor enter \"none\" to disable the --cookies-from-browser option (login to YouTube Premium and enter a valid browser for best audio quality)." && ((validation_errors++))
	fi
else
	browser=firefox
fi

# Validate engine
if [[ ! -z "$engine" ]]; then
	supported_engines=(warptempo rubberband bungee stretch soundtouch midi none)
	supported=false
	for supported_engine in "${supported_engines[@]}"; do
		if [[ "$engine" == "$supported_engine" ]]; then
			supported=true
			break
		fi
	done
	if ! $supported; then
		echo -e "Error: Engine is not supported. Enter one of the following:\n${supported_engines[@]}" && ((validation_errors++))
	fi
else
	engine=warptempo
fi

if [[ $validation_errors -gt 0 ]]; then
	exit 1
fi

#Compiler
CXX="${CXX:-g++}"

# Check dependencies
requirements=(bc ffmpeg ffprobe jq sox yt-dlp)
if [[ "$engine" == warptempo ]]; then
	warptempo_engine_path="$script_dir/build/warptempo_engine"
	if [[ ! -x "$warptempo_engine_path" ]]; then
		echo "Error: Warptempo engine not found at $warptempo_engine_path" && ((requirement_errors++))
	fi
fi
if [[ "$engine" == rubberband ]]; then
	requirements+=(rubberband)
fi
if [[ "$engine" == bungee ]]; then
	bungee_adapter_path="$script_dir/adapters/bungee/build/bungee_adapter"
	if [[ ! -x "$bungee_adapter_path" ]]; then
		echo "Error: Bungee adapter not found at $bungee_adapter_path" && ((requirement_errors++))
	fi
fi
if [[ "$engine" == stretch ]]; then
	stretch_adapter_path="$script_dir/adapters/stretch/build/stretch_adapter"
	if [[ ! -x "$stretch_adapter_path" ]]; then
		echo "Error: Signalsmith Stretch adapter not found at $stretch_adapter_path" && ((requirement_errors++))
	fi
fi
if [[ "$engine" == soundtouch ]]; then
	soundtouch_adapter_path="$script_dir/adapters/soundtouch/build/soundtouch_adapter"
	if [[ ! -x "$soundtouch_adapter_path" ]]; then
		echo "Error: SoundTouch adapter not found at $soundtouch_adapter_path" && ((requirement_errors++))
	fi
fi
if [[ "$engine" == midi ]]; then
	midi_adapter_path="$script_dir/adapters/midi/build/midi_adapter"
	if [[ ! -x "$midi_adapter_path" ]]; then
		echo "Error: MIDI adapter not found at $midi_adapter_path" && ((requirement_errors++))
	fi
fi
requirement_errors=0

for requirement in "${requirements[@]}"; do
	if ! type "$requirement" &> /dev/null; then
		echo "Error: $requirement is not installed." && ((requirement_errors++))
	fi
done

if [[ $requirement_errors -gt 0 ]]; then
	echo "Requirements: ${requirements[*]}"
	exit 1
fi

# Download audio if not local
if [[ ! -f "$audio_input" ]]; then
	if [[ "$browser" == none ]]; then
		best_audio=$(yt-dlp -J "$url" | jq -r '
			.formats 
			| map(select(.vcodec == "none")) 
			| sort_by(.abr // 0) 
			| reverse 
			| .[0]
		')
	else
		best_audio=$(yt-dlp -J --cookies-from-browser $browser "$url" | jq -r '
			.formats 
			| map(select(.vcodec == "none")) 
			| sort_by(.abr // 0) 
			| reverse 
			| .[0]
		')
	fi
	
	# Determine extension
	format_id=$(echo "$best_audio" | jq -r '.format_id')
	acodec=$(echo "$best_audio" | jq -r '.acodec')
	case "$acodec" in
		opus) ext="opus" ;;
		vorbis) ext="ogg" ;;
		mp4a*|aac) ext="m4a" ;;
		mp3) ext="mp3" ;;
		flac) ext="flac" ;;
		alac) ext="m4a" ;;
		*) ext="m4a" ;;
	esac
	
	if [[ "$browser" == none ]]; then
		base_filename=$(yt-dlp --restrict-filenames -f "$format_id" --print filename -o "%(title)s-[%(id)s]" "$url")
	else
		base_filename=$(yt-dlp --restrict-filenames -f "$format_id" --print filename -o "%(title)s-[%(id)s]" --cookies-from-browser $browser "$url")
	fi
	filename="$base_filename.$ext"
	
	# Update setting if filename differs
	if [[ "$audio_input" != "$filename" ]]; then
		sed -i "s/audio_input=.*/audio_input=\"$filename\"/" "$settings_file"
		audio_input="$filename"
	fi

	# Perform download
	if [[ ! -f "$audio_input" ]]; then
		if [[ "$browser" == none ]]; then
			echo "Downloading source file..."
			yt-dlp -f bestaudio --extract-audio --restrict-filenames "$url"
		else
			echo "Downloading source file... (login to YouTube Premium for best audio quality)"
			yt-dlp -f bestaudio --extract-audio --restrict-filenames --cookies-from-browser $browser "$url"
		fi
		
		# Wait for download completion
		count=0
		timeout=3600
		while [[ ! -f "$audio_input" ]]; do
			sleep 1
			((count++))
			if [[ $count -ge $timeout ]]; then
				echo "Error: Download timed out ($timeout). Download file manually and set audio_input." && exit 1
			fi
		done
	fi
fi

# Prepare temp files
md5=$(md5sum "$audio_input" | cut -d ' ' -f 1)
audio_output="$title.wav"
mkdir -p "$(dirname "$audio_output")"
log_output="$title.log"

rm -f .$md5-timemap* .$md5-labels* .$md5-trimmed.wav .$md5-tmp*.wav .$md5-tmp*.png *"$title.wav" *"$title.log"

# Get audio stats
sample_rate="$(ffprobe -hide_banner -loglevel error -show_streams "$audio_input" | grep "^sample_rate=" | head -n 1 | cut -d = -f 2)"
total_frames="$(ffprobe -hide_banner -loglevel error -show_streams "$audio_input" | grep "^duration_ts=" | head -n 1 | cut -d = -f 2)"
total_seconds="$(ffprobe -hide_banner -loglevel error -show_format "$audio_input" | grep "^duration=" | head -n 1 | cut -d = -f 2)"
total_time_ms=$(echo $(date -d@"$(printf "%.3f\n" "$total_seconds")" -u +%M:%S.%N) | cut -c1-9)

if [[ "$(cat -e "$warpmarkers_file" | tail -n 1)" != *"$" ]]; then 
	echo >> "$warpmarkers_file"
fi

# Parser
parser_binary="$script_dir/build/parser"

if [[ ! -f "$parser_binary" ]]; then
	echo "Parser not found."
    exit 1
fi

# Run Parser
parser_output=$("$parser_binary" "$warpmarkers_file" "$settings_file" "$audio_input" "$sample_rate" "$total_frames" "$md5" "$log_file" "$total_time_ms")

# Check for failure
if [ $? -ne 0 ]; then
    echo "Error in parsing warpmarkers."
    exit 1
fi

# Check if the parser trimmed the file and updated the audio input
updated_input=$(echo "$parser_output" | grep "AUDIO_INPUT_UPDATED" | cut -d = -f 2)
if [[ ! -z "$updated_input" ]]; then
    audio_input="$updated_input"
fi

# Adapter / Engine Execution
if [[ "$engine" == warptempo ]]; then

	"$warptempo_engine_path" "$audio_input" .$md5-timemap .$md5-transientmap $md5 \
		N=4096 \
		flex_window=1
		
	#exit

elif [[ "$engine" == rubberband ]]; then
	sed -i '/^0 0$/d' .$md5-timemap
	# Run rubberband
	rubberband -t 1 --timemap .$md5-timemap --fine --ignore-clipping "$audio_input" .$md5-tmp.wav
elif [[ "$engine" == bungee ]]; then
	# Run bungee_adapter
	"$bungee_adapter_path" "$audio_input" .$md5-timemap .$md5-tmp.wav
elif [[ "$engine" == stretch ]]; then
	# Run stretch_adapter
	"$stretch_adapter_path" "$audio_input" .$md5-timemap .$md5-tmp.wav
elif [[ "$engine" == soundtouch ]]; then
	"$soundtouch_adapter_path" "$audio_input" .$md5-tmp.wav .$md5-timemap
elif [[ "$engine" == midi ]]; then
	# Run midi_adapter
	base_bpm="$(echo "$sample_rate*.002" | bc -l)"
	ppq=30000
	"$midi_adapter_path" .$md5-timemap-midi .midi.mid "$base_bpm" "$ppq"
	if [[ -f .$md5-trimmed.wav ]]; then
		mv .$md5-trimmed.wav .trimmed.wav
	elif [[ "${audio_input,,}" != *.wav ]]; then
		if [[ -f "${audio_input%.*}.wav" ]]; then
			fmt=$(ffprobe -v error -select_streams a:0 -show_entries stream=sample_fmt -of default=noprint_wrappers=1:nokey=1 "${audio_input%.*}.wav")
			if [[ "$fmt" != "flt" ]]; then
				echo "File exists but is $fmt (not 32-bit float). Removing and re-rendering as 32-bit float."
				rm "${audio_input%.*}.wav"
				ffmpeg -i "$audio_input" -vn -c:a pcm_f32le "${audio_input%.*}.wav"
			fi
		elif [[ ! -f "${audio_input%.*}.wav" ]]; then
			ffmpeg -i "$audio_input" -vn -c:a pcm_f32le "${audio_input%.*}.wav"
		fi
	fi
	mv .$md5-timemap-midi .timemap-midi
	mv .$md5-timemap .timemap
	rm -f .$md5-timemap* .$md5-labels* .$md5-trimmed.wav .$md5-tmp.wav
	exit
elif [[ "$engine" == none ]]; then
	# Save timemap
	mv .$md5-timemap .timemap
	mv .$md5-timemap-midi .timemap-midi
	rm -f .$md5-timemap* .$md5-labels* .$md5-trimmed.wav .$md5-tmp.wav
	exit
fi

mv .$md5-timemap .timemap
[[ -f .$md5-tmp_eq.png ]] && mv .$md5-tmp_eq.png .eq.png

# Apply limiting or copy
if $limiter; then
	af="alimiter=latency=enabled:level=disabled:asc=disabled"
	af+=":level_in=0dB"
	af+=":limit=${limit}dB"
	af+=":level_out=0dB"
	af+=":attack=10"
	af+=":release=20"

	ffmpeg -i .$md5-tmp.wav -c:a pcm_s24le -af "$af" "$audio_output"
else
	clip_warning="\033[31mWarning:\033[0m Output may contain clipping. Use an external limiter to prevent clipping."
	mv .$md5-tmp.wav "engine=$engine;limiter=$limiter;$audio_output"
	echo
	echo -e "$clip_warning"
fi

