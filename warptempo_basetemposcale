#!/bin/bash
#run only from terminal
if [ ! -t 0 ]; then exit; fi
shopt -s nocaseglob
set -e

if [[ "$1" == help ]] || [[ "$1" == -h ]] || [[ "$1" == --help ]]; then
	echo "Calculate base tempo and scale."
	echo
	echo "   Usage: "$(basename "$0")" <start> <end> <num_beats> <target_bpm>"
    echo "   Time format: MM:SS.mmm"
	exit
fi

if [ $# -ne 4 ]; then
    exit 1
fi

START="$1"
END="$2"
BEATS="$3"
BPM="$4"

# Function to convert MM:SS.mmm → seconds (as decimal)
time_to_seconds() {
    local t="$1"
    # Split into minutes, seconds, milliseconds
    local mins=${t%%:*}
    local rest=${t#*:}
    local secs=${rest%.*}
    local millis=${rest#*.}

    # Pad millis to 3 digits if needed
    millis=$(printf "%-3s" "$millis" | tr ' ' '0')

    # Calculate total seconds with 3 decimal places
    printf "%.3f" "$(echo "$mins * 60 + $secs + $millis / 1000" | bc -l)"
}

# Convert both timestamps to seconds
start_sec=$(time_to_seconds "$START")
end_sec=$(time_to_seconds "$END")

# Duration in seconds
duration=$(echo "$end_sec - $start_sec" | bc -l)

# Desired duration for the given number of beats at target BPM
# One beat = 60 / BPM seconds → N beats = N * 60 / BPM seconds
desired_duration=$(echo "$BEATS * 60 / $BPM" | bc -l)

# Ratio = desired_duration / actual_duration
ratio=$(echo "$duration / $desired_duration" | bc -l)

echo "ratio: $ratio"
base_tempo=$(printf "%0.2f" $ratio)
echo "base_tempo: $base_tempo"
# Add epsilon to compensate for binary representation error
scale=$(printf "%0.6f" $(echo "($ratio / $base_tempo) + 0.00000001" | bc -l))
echo "scale: $scale"











